{
  gateway: {
    port: 18789,
  },

  agents: {
    defaults: {
      userTimezone: "Asia/Tokyo",
      timeFormat: "24",
      skipBootstrap: false,
    },

    list: [
      {
        id: "family-intake-agent",
        default: true,
        name: "Family Intake Agent",
        workspace: "__PROJECT_ROOT__/gateway/openclaw_gateway/workspaces/family-intake-agent",
        tools: {
          profile: "coding",
          allow: [
            "read",
            "write",
            "edit",
            "apply_patch",
            "exec",
            "process",
            "nodes",
            "gateway",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "session_status",
          ],
        },
        subagents: {
          allowAgents: ["household-dashboard-agent", "voice-automation-agent", "home-orchestrator-agent"],
        },
      },
      {
        id: "household-dashboard-agent",
        name: "Household Dashboard Agent",
        workspace: "__PROJECT_ROOT__/gateway/openclaw_gateway/workspaces/household-dashboard-agent",
        tools: {
          profile: "coding",
          allow: [
            "read",
            "exec",
            "process",
            "nodes",
            "gateway",
            "sessions_list",
            "sessions_history",
            "session_status",
          ],
          deny: ["write", "edit", "apply_patch"],
        },
      },
      {
        id: "voice-automation-agent",
        name: "Voice Automation Agent",
        workspace: "__PROJECT_ROOT__/gateway/openclaw_gateway/workspaces/voice-automation-agent",
        tools: {
          profile: "coding",
          allow: [
            "read",
            "exec",
            "process",
            "nodes",
            "gateway",
            "sessions_list",
            "sessions_history",
            "session_status",
          ],
          deny: ["write", "edit", "apply_patch"],
        },
      },
      {
        id: "home-orchestrator-agent",
        name: "Home Orchestrator Agent",
        workspace: "__PROJECT_ROOT__/gateway/openclaw_gateway/workspaces/home-orchestrator-agent",
        tools: {
          profile: "coding",
          allow: [
            "read",
            "exec",
            "process",
            "nodes",
            "gateway",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "session_status",
          ],
          deny: ["write", "edit", "apply_patch"],
        },
      },
    ],
  },
}
