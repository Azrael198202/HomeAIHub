{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Box: develop",
      "type": "debugpy",
      "request": "launch",
      "module": "box",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/box/env/.env.develop",
      "env": {
        "HOMEAIHUB_BOX_HOST": "127.0.0.1",
        "HOMEAIHUB_BOX_PORT": "8090",
        "HOMEAIHUB_DB_NAME": "home_ai_hub.vscode.box.db",
        "HOMEAIHUB_ASR_BACKEND": "auto",
        "HOMEAIHUB_ASR_WHISPER_MODEL": "base",
        "HOMEAIHUB_ASR_WHISPER_LANGUAGE": "auto",
        "HOMEAIHUB_ASR_WHISPER_CACHE_DIR": "${workspaceFolder}/data/whisper-cache",
        "HOMEAIHUB_MIC_BACKEND": "auto",
        "HOMEAIHUB_MIC_DEVICE_INDEX": "1",
        "HOMEAIHUB_MIC_DURATION_SECONDS": "6",
        "HOMEAIHUB_MIC_SAMPLE_RATE": "16000",
        "HOMEAIHUB_MIC_CHANNELS": "1",
        "HOMEAIHUB_MIC_LISTENER_POLL_SECONDS": "2",
        "HOMEAIHUB_VOICE_LISTENER_AUTOSTART": "true",
        "HOMEAIHUB_TV_DASHBOARD_URL": "http://127.0.0.1:8090/dashboard",
        "HOMEAIHUB_TV_DASHBOARD_BROWSER_AUTOLAUNCH": "true",
        "HOMEAIHUB_TTS_BACKEND": "google_cloud",
        "HOMEAIHUB_TTS_VOICE_NAME": "",
        "HOMEAIHUB_TTS_RATE": "0",
        "HOMEAIHUB_GOOGLE_TTS_API_KEY": "AIzaSyDX_b5k7rVPHZ_vLWgMp2nBTdBOwUYNyms",
        "HOMEAIHUB_GOOGLE_TTS_VOICE_NAME": "en-US-Neural2-F",
        "HOMEAIHUB_GOOGLE_TTS_LANGUAGE_CODE": "en-US",
        "HOMEAIHUB_GOOGLE_TTS_GENDER": "FEMALE",
        "HOMEAIHUB_GOOGLE_TTS_SPEAKING_RATE": "1.0",
        "HOMEAIHUB_GOOGLE_TTS_CACHE_DIR": "${workspaceFolder}/data/google-tts-cache"
      }
    },
    {
      "name": "Gateway: local preview",
      "type": "debugpy",
      "request": "launch",
      "module": "home_ai_hub",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "HOMEAIHUB_HOST": "127.0.0.1",
        "HOMEAIHUB_PORT": "8080",
        "HOMEAIHUB_BOX_HOST": "127.0.0.1",
        "HOMEAIHUB_BOX_PORT": "8090",
        "HOMEAIHUB_GATEWAY_BASE_URL": "http://127.0.0.1:8080",
        "HOMEAIHUB_RAILWAY_PUBLIC_BASE_URL": "http://127.0.0.1:8080",
        "HOMEAIHUB_RAILWAY_API_BASE_URL": "",
        "HOMEAIHUB_BOX_SYNC_INTERVAL_SECONDS": "10",
        "HOMEAIHUB_DB_NAME": "home_ai_hub.vscode.gateway.db",
        "HOMEAIHUB_ASR_BACKEND": "auto",
        "HOMEAIHUB_ASR_WHISPER_MODEL": "base",
        "HOMEAIHUB_ASR_WHISPER_LANGUAGE": "auto",
        "HOMEAIHUB_ASR_WHISPER_CACHE_DIR": "${workspaceFolder}/data/whisper-cache",
        "HOMEAIHUB_MIC_BACKEND": "auto",
        "HOMEAIHUB_MIC_DEVICE_INDEX": "1"
      }
    }
  ],
  "compounds": [
    {
      "name": "Local Preview: box + gateway",
      "configurations": [
        "Box: develop",
        "Gateway: local preview"
      ],
      "stopAll": true
    }
  ]
}
