{
  gateway: {
    auth: {
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  agents: {
    defaults: {
      userTimezone: "Asia/Tokyo",
      timeFormat: "24",
      skipBootstrap: false,
      tools: {
        profile: "coding",
      },
    },

    list: [
      {
        id: "family-assistant",
        default: true,
        name: "Family Assistant",
        workspace: "/app/gateway/openclaw_gateway/workspaces/family-assistant",
        tools: {
          profile: "coding",
        },
      },
      {
        id: "home-automation-assistant",
        name: "Home Automation Assistant",
        workspace: "/app/gateway/openclaw_gateway/workspaces/home-automation-assistant",
        tools: {
          profile: "coding",
        },
      },
    ],
  },
}
