{
  gateway: {
    bind: "lan",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    controlUi: {
      allowedOrigins: ["${OPENCLAW_CONTROL_UI_ALLOWED_ORIGIN}"],
      dangerouslyDisableDeviceAuth: true,
    },
  },

  agents: {
    defaults: {
      userTimezone: "Asia/Tokyo",
      timeFormat: "24",
      skipBootstrap: false,
    },

    list: [
      {
        id: "family-assistant",
        default: true,
        name: "Family Assistant",
        workspace: "/app/gateway/openclaw_gateway/workspaces/family-assistant",
        tools: {
          profile: "coding",
        },
      },
      {
        id: "home-automation-assistant",
        name: "Home Automation Assistant",
        workspace: "/app/gateway/openclaw_gateway/workspaces/home-automation-assistant",
        tools: {
          profile: "coding",
        },
      },
    ],
  },
}
